# Copiá este archivo como .env y completá los valores.
# Todas las variables VITE_ son públicas (se exponen en el browser): no pongas secretos acá.

# --- Supabase (ya configurado) ---
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# --- Sitio / contacto ---
VITE_SITE_URL="https://meiba.com.ar"
VITE_CONTACT_EMAIL="contacto@meiba.com.ar"
# WhatsApp en formato internacional, solo números (ej: 5491122334455). Vacío = oculta los botones.
VITE_WHATSAPP_NUMBER=""
# Link de agenda (Calendly / Cal.com / Google). Vacío = oculta el botón "Agendar".
VITE_CALENDAR_URL=""

# --- Analytics ---
# Google Analytics 4 -> https://analytics.google.com (ID con formato G-XXXXXXX)
VITE_GA4_ID=""
# Meta Pixel -> Administrador de eventos de Meta (ID numérico)
VITE_META_PIXEL_ID=""
# Google Ads -> ID de conversión (formato AW-XXXXXXXXX)
VITE_GOOGLE_ADS_ID=""
# Google Ads -> label de la acción de conversión "lead"
VITE_GOOGLE_ADS_LEAD_LABEL=""
